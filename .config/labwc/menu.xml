<?xml version="1.0" encoding="UTF-8"?>
<openbox_menu>
  <!-- Right-click menu on the desktop -->
  <menu id="root-menu" label="Applications">
    <item label="Terminal (foot)">
      <action name="Execute" command="footclient" />
    </item>
    <item label="Launcher (wofi)">
      <action name="Execute" command="wofi --show drun" />
    </item>
    <item label="File Manager (nnn)">
      <action name="Execute" command="footclient nnn" />
    </item>
    <separator />
    <item label="Reconfigure">
      <action name="Reconfigure" />
    </item>
    <item label="Exit">
      <action name="Exit" />
    </item>
  </menu>
</openbox_menu>
