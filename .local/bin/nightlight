#!/bin/bash
case "${1:-}" in
    status)
        if pgrep -x wlsunset >/dev/null; then
            echo '{"text":"","tooltip":"Night light on","class":"on"}'
        else
            echo '{"text":"","tooltip":"Night light off","class":"off"}'
        fi
        exit 0
        ;;
    toggle|*)
        if pgrep -x wlsunset >/dev/null; then
            pkill wlsunset
        else
            # adjust lat/long for your location
            wlsunset -l 52.5 -L 13.4 &
        fi
        ;;
esac
